# 로컬 개발용 기본값. prod는 systemd EnvironmentFile로 주입.

APP_ENV=dev
APP_ADDR=:8080
LOG_LEVEL=info

# SQLite 파일 경로 (상대경로 → 절대경로 변환)
DB_PATH=./var/yuhada.db

# 세션 쿠키 서명 (dev에서는 임의값 OK, prod는 32B 이상 무작위)
SESSION_SECRET=dev-secret-change-me-in-production-0000000000

# 쿠키 보안 (prod=true; https 필수)
COOKIE_SECURE=false

# 첫 실행 시 관리자 부트스트랩.
# email: 식별자 (DB unique key, 로그인 화면에는 노출 X — PIN으로만 인증)
# pin:   6자리. 로그인 시 사용하는 메인 인증 수단.
# pw:    선택. fallback 비번 (현재 로그인 UI는 PIN만 노출)
ADMIN_BOOTSTRAP_EMAIL=
ADMIN_BOOTSTRAP_PIN=
ADMIN_BOOTSTRAP_PW=

# 알리고 SMS API (빈값이면 SMS 비활성)
# API 키 발급: https://smartsms.aligo.in
ALIGO_API_KEY=
ALIGO_USER_ID=
ALIGO_SENDER=

# PII 암호화 키 (32바이트 = 64 hex chars). 빈값이면 암호화 비활성.
# 생성: openssl rand -hex 32
ENCRYPTION_KEY=

# Kakao OAuth (Step 11)
KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=
KAKAO_REDIRECT_URL=https://yhd.cafe24.com/c/kakao/callback
