# Go
/dist/
*.test
*.out
vendor/

# SQLite runtime (로컬 DB + WAL/SHM 파일)
/var/*.db
/var/*.db-wal
/var/*.db-shm
/var/backup/

# Manual backups (운영 DB 백업 — PII 포함, 절대 커밋 금지)
/_backups/

# 하네스 작업 산출물 (감사 추적용, 커밋 제외)
/_workspace/

# templ generated (opt-in: 저장소에 커밋하지 않음)
internal/view/**/*_templ.go

# Tailwind CSS (generated output)
static/css/app.css
tailwind/bin/

# sqlc generated은 커밋 (Go 파일은 추적)
# internal/db/sqlc/ → 커밋됨

# .env (dev 개인별 설정)
.env
.env.local
.env.*.local
!.env.example

# IDE / OS
.DS_Store
.idea/
.vscode/
*.swp

# Excluded from repo
/.archive/
/.claude/
/_handoff/
/design_handoff_yuhada/
/supabase/
